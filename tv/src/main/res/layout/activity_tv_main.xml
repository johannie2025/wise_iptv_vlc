<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wise_bg">

    <FrameLayout
        android:id="@+id/browse_fragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:nextFocusUp="@id/btn_search"
        android:paddingTop="68dp"/>

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#EE0A0A0F"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="8dp"
        android:focusable="false">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:focusable="false"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Wise IPTV"
            android:focusable="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_search"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="🔍"
            android:textSize="25sp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/browse_fragment"
            android:background="@drawable/btn_action_selector"
            android:layout_marginStart="6dp"/>

        <TextView
            android:id="@+id/btn_add"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="➕"
            android:textSize="20sp"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/browse_fragment"
            android:background="@drawable/btn_action_selector"
            android:layout_marginStart="6dp"/>

        <TextView
            android:id="@+id/btn_sync"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="🔄"
            android:textSize="20sp"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/browse_fragment"
            android:background="@drawable/btn_action_selector"
            android:layout_marginStart="6dp"/>

        <TextView
            android:id="@+id/btn_recents"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="🕐"
            android:textSize="20sp"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/browse_fragment"
            android:background="@drawable/btn_action_selector"
            android:layout_marginStart="6dp"/>

        <TextView
            android:id="@+id/tv_sync_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/wise_blue_light"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:visibility="gone"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:indeterminateTint="@color/wise_red"
            android:visibility="gone"/>
    </LinearLayout>
</FrameLayout>