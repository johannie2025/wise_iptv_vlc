<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="#1F1F1F">

    <LinearLayout 
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText 
            android:id="@+id/et_playlist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nom de la playlist" 
            android:textColor="#FFFFFF"
            android:textColorHint="#88FFFFFF"
            android:layout_marginBottom="16dp"
            android:focusable="true"
            android:nextFocusDown="@+id/rb_m3u_url" />

        <TextView 
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type de source" 
            android:textStyle="bold" 
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"/>

        <RadioGroup 
            android:id="@+id/rg_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal" 
            android:layout_marginBottom="16dp">
            
            <RadioButton 
                android:id="@+id/rb_m3u_url"  
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" 
                android:text="URL M3U" 
                android:textColor="#FFFFFF"
                android:checked="true"
                android:focusable="true"
                android:nextFocusUp="@+id/et_playlist_name"
                android:nextFocusRight="@+id/rb_m3u_file"
                android:nextFocusDown="@+id/et_playlist_url" />
                
            <RadioButton 
                android:id="@+id/rb_m3u_file" 
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" 
                android:text="Fichier local" 
                android:textColor="#FFFFFF"
                android:layout_marginStart="16dp"
                android:focusable="true"
                android:nextFocusUp="@+id/et_playlist_name"
                android:nextFocusLeft="@+id/rb_m3u_url"
                android:nextFocusRight="@+id/rb_xtream"
                android:nextFocusDown="@+id/btn_pick_file" />
                
            <RadioButton 
                android:id="@+id/rb_xtream" 
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" 
                android:text="Xtream" 
                android:textColor="#FFFFFF"
                android:layout_marginStart="16dp"
                android:focusable="true"
                android:nextFocusUp="@+id/et_playlist_name"
                android:nextFocusLeft="@+id/rb_m3u_file"
                android:nextFocusDown="@+id/et_xtream_server" />
        </RadioGroup>

        <LinearLayout 
            android:id="@+id/layout_m3u_url"
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:orientation="vertical" 
            android:visibility="visible">
            
            <EditText 
                android:id="@+id/et_playlist_url"
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:hint="URL M3U : http://..." 
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:inputType="textUri"
                android:focusable="true"
                android:nextFocusUp="@+id/rb_m3u_url"
                android:nextFocusDown="@+id/et_epg_url" />
        </LinearLayout>

        <LinearLayout 
            android:id="@+id/layout_file"
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:orientation="vertical" 
            android:visibility="gone"
            android:paddingBottom="8dp">
            
            <TextView 
                android:id="@+id/tv_file_path"
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Aucun fichier sélectionné" 
                android:textColor="#88FFFFFF"
                android:textStyle="italic"
                android:layout_marginBottom="8dp"/>
                
            <Button 
                android:id="@+id/btn_pick_file"
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:text="📂 Parcourir…" 
                android:textSize="14sp"
                android:focusable="true"
                android:background="@android:drawable/btn_default"
                android:nextFocusUp="@+id/rb_m3u_file"
                android:nextFocusDown="@+id/et_epg_url" />
        </LinearLayout>

        <LinearLayout 
            android:id="@+id/layout_xtream"
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:orientation="vertical" 
            android:visibility="gone">
            
            <EditText 
                android:id="@+id/et_xtream_server"
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:hint="Serveur : http://..." 
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:inputType="textUri"
                android:layout_marginBottom="8dp"
                android:focusable="true"
                android:nextFocusUp="@+id/rb_xtream"
                android:nextFocusDown="@+id/et_xtream_user" />
                
            <EditText 
                android:id="@+id/et_xtream_user"
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:hint="Nom d'utilisateur" 
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:layout_marginBottom="8dp"
                android:focusable="true"
                android:nextFocusUp="@+id/et_xtream_server"
                android:nextFocusDown="@+id/et_xtream_pass" />
                
            <EditText 
                android:id="@+id/et_xtream_pass"
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:hint="Mot de passe" 
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:inputType="textPassword"
                android:focusable="true"
                android:nextFocusUp="@+id/et_xtream_user"
                android:nextFocusDown="@+id/et_epg_url" />
        </LinearLayout>

        <EditText 
            android:id="@+id/et_epg_url"
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:hint="URL EPG (optionnel) : http://..." 
            android:textColor="#FFFFFF"
            android:textColorHint="#88FFFFFF"
            android:inputType="textUri"
            android:layout_marginTop="12dp"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>