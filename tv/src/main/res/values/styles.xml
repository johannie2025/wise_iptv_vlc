<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WiseIPTV.TV" parent="Theme.Leanback">
        <item name="colorPrimary">@color/wise_blue</item>
        <item name="colorPrimaryDark">@color/wise_blue_dark</item>
        <item name="colorAccent">@color/wise_red</item>
        <item name="android:colorBackground">@color/wise_bg</item>
        <item name="android:windowBackground">@color/wise_bg</item>
